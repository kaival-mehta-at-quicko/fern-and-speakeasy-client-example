            "description": ""
          },
          "504": {
            "$ref": "#/components/responses/GatewayTimeout",
            "description": ""
          },
          "505": {
            "$ref": "#/components/responses/VersionNotSupported",
            "description": ""
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "x-sandbox-client-name": "Protean"
      }
    }
  },
